{% extends 'base_landing.html.twig' %}

{% block title %}My Profile - MVLLI{% endblock %}

{% block body %}
<style>
    @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@400;500;600;700&display=swap');
    
    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }
    
    body {
        background: #f5f5f5;
        font-family: 'DM Sans', sans-serif;
        color: #2d4a2b;
        line-height: 1.6;
    }
    
    .profile-container {
        padding: 40px 30px;
        max-width: 600px;
        margin: 0 auto;
        background: #f5f5f5;
        min-height: calc(100vh - 80px);
    }
    
    .profile-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }
    
    .page-title {
        font-family: 'Playfair Display', serif;
        font-size: 2rem;
        font-weight: 700;
        color: #2d4a2b;
        margin: 0;
    }
    
    .change-password-btn {
        padding: 14px 28px;
        background: linear-gradient(135deg, #2d4a2b 0%, #3a5a40 100%);
        color: white;
        text-decoration: none;
        border-radius: 10px;
        font-weight: 600;
        font-family: 'DM Sans', sans-serif;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(45, 74, 43, 0.3);
    }
    
    .change-password-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(45, 74, 43, 0.4);
        background: linear-gradient(135deg, #3a5a40 0%, #4a6b50 100%);
    }
    
    .profile-card {
        background: white;
        border-radius: 16px;
        padding: 28px;
        border: 1px solid #e0e0e0;
        box-shadow: 0 2px 4px rgba(45, 74, 43, 0.1);
    }
    
    .profile-info {
        display: grid;
        grid-template-columns: 1fr 2fr;
        gap: 24px;
        align-items: center;
    }
    
    .info-label {
        font-weight: 600;
        color: #2d4a2b;
        font-family: 'DM Sans', sans-serif;
        margin-bottom: 8px;
    }
    
    .info-value {
        color: #333333;
        font-family: 'DM Sans', sans-serif;
    }

    .role-badge {
        display: inline-block;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
    }

    .role-badge--customer {
        background: #e8f5e9;
        color: #2e7d32;
    }

    .role-badge--staff {
        background: #e3f2fd;
        color: #1565c0;
    }

    .role-badge--admin {
        background: #ffebee;
        color: #c62828;
    }
    
    .flash-message {
        background: #d4edda;
        color: #155724;
        padding: 12px;
        border-radius: 8px;
        margin-bottom: 20px;
        border-left: 4px solid #28a745;
        font-family: 'DM Sans', sans-serif;
    }
    
    .flash-message.error {
        background: #f8d7da;
        color: #721c24;
        border-left: 4px solid #dc3545;
    }
    
    @media (max-width: 768px) {
        .profile-container {
            padding: 20px;
        }
        
        .page-title {
            font-size: 1.8rem;
        }
        
        .profile-info {
            grid-template-columns: 1fr;
            gap: 16px;
        }
    }
</style>

<div class="profile-container">
    <div class="profile-header">
        <h1 class="page-title">👤 My Profile</h1>
        <a href="{{ path('app_profile_change_password') }}" class="change-password-btn">
            <i class="fas fa-key"></i> Change Password
        </a>
    </div>

    {% for message in app.flashes('success') %}
        <div class="flash-message">
            {{ message }}
        </div>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <div class="flash-message error">
            {{ message }}
        </div>
    {% endfor %}

    <div class="profile-card">
        <div class="profile-info">
            <div>
                <span class="info-label">ID:</span>
                <span class="info-value">{{ user.id }}</span>
            </div>
            <div>
                <span class="info-label">Username:</span>
                <span class="info-value">{{ user.username }}</span>
            </div>
            <div>
                <span class="info-label">Email:</span>
                <span class="info-value">{{ user.email }}</span>
            </div>
            <div>
                <span class="info-label">Name:</span>
                <span class="info-value">{{ user.name }}</span>
            </div>
            <div>
                <span class="info-label">Account type:</span>
                <span class="info-value">
                    <span class="role-badge role-badge--{{ user.roleLabel|lower }}">{{ user.roleLabel }}</span>
                </span>
            </div>
            <div>
                <span class="info-label">Status:</span>
                <span class="info-value">{{ user.isActive ? 'Active' : 'Inactive' }}</span>
            </div>
            <div>
                <span class="info-label">Member since:</span>
                <span class="info-value">{{ user.createdAt|date('M d, Y') }}</span>
            </div>
        </div>
    </div>
</div>
{% endblock %}

