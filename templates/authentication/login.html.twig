{% extends 'base_landing.html.twig' %}

{% block title %}Login - MVLLI{% endblock %}

{% block body %}
<style>
    @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@400;500;600;700&display=swap');
    
    body {
        background: linear-gradient(135deg, #f5f5f5 0%, #ffffff 50%, #f0f0f0 100%);
        min-height: 100vh;
        font-family: 'DM Sans', sans-serif;
    }
    
    .login-overlay {
        background: rgba(45, 74, 43, 0.9);
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
    }
    
    .login-container {
        background: white;
        border-radius: 20px;
        box-shadow: 0 20px 60px rgba(45, 74, 43, 0.2);
        padding: 50px;
        max-width: 450px;
        width: 100%;
        backdrop-filter: blur(10px);
        border: 1px solid rgba(45, 74, 43, 0.1);
    }
    
    .login-header {
        text-align: center;
        margin-bottom: 40px;
    }
    
    .login-header h1 {
        color: #2d4a2b;
        font-size: 2.5rem;
        font-weight: 700;
        font-family: 'Playfair Display', serif;
        margin-bottom: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
    }
    
    .login-logo {
        position: absolute;
        top: -40px;
        left: 50%;
        transform: translateX(-50%);
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, #2d4a2b 0%, #3a5a40 100%);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 8px 20px rgba(45, 74, 43, 0.3);
        z-index: 10;
    }
    
    .login-logo img {
        width: 50px;
        height: 50px;
    }
    
    .login-icon {
        width: 50px;
        height: 50px;
        background: linear-gradient(135deg, #2d4a2b 0%, #3a5a40 100%);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1.5rem;
    }
    
    .error-alert {
        background: rgba(248, 215, 97, 0.95);
        color: #721c24;
        padding: 16px 20px;
        border-radius: 12px;
        margin-bottom: 25px;
        border: 1px solid rgba(248, 215, 97, 0.3);
        text-align: center;
        font-size: 0.95rem;
    }
    
    .form-group {
        margin-bottom: 24px;
    }
    
    .form-group label {
        display: block;
        margin-bottom: 8px;
        color: #2d4a2b;
        font-weight: 600;
        font-size: 1rem;
        font-family: 'DM Sans', sans-serif;
    }
    
    .form-control {
        width: 100%;
        padding: 16px;
        border: 2px solid #e0e0e0;
        border-radius: 12px;
        font-size: 1rem;
        font-family: 'DM Sans', sans-serif;
        transition: all 0.3s ease;
        background: #fafafa;
    }
    
    .form-control:focus {
        outline: none;
        border-color: #2d4a2b;
        background: white;
        box-shadow: 0 0 0 3px rgba(45, 74, 43, 0.1);
    }
    
    .btn-login {
        background: linear-gradient(135deg, #2d4a2b 0%, #3a5a40 100%);
        color: white;
        padding: 16px 24px;
        border: none;
        border-radius: 12px;
        font-size: 1.1rem;
        font-weight: 700;
        font-family: 'DM Sans', sans-serif;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(45, 74, 43, 0.3);
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }
    
    .btn-login:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(45, 74, 43, 0.4);
        background: linear-gradient(135deg, #3a5a40 0%, #4a6b50 100%);
    }
    
    .btn-google {
        background: white;
        color: #3c4043;
        padding: 14px 24px;
        border: 2px solid #dadce0;
        border-radius: 12px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        text-decoration: none;
        margin-top: 16px;
    }
    
    .btn-google:hover {
        background: #f8f9fa;
        border-color: #2d4a2b;
        box-shadow: 0 4px 12px rgba(45, 74, 43, 0.15);
        transform: translateY(-2px);
        color: #2d4a2b;
    }
    
    .register-link {
        text-align: center;
        margin-top: 25px;
        color: white;
    }
    
    .register-link a {
        color: white;
        text-decoration: none;
        font-weight: 600;
        font-size: 1rem;
        transition: all 0.3s ease;
        padding: 8px 16px;
        border-radius: 8px;
        border: 1px solid rgba(255, 255, 255, 0.3);
    }
    
    .register-link a:hover {
        background: rgba(255, 255, 255, 0.1);
        transform: translateY(-2px);
    }
    
    @media (max-width: 480px) {
        .login-container {
            margin: 20px;
            padding: 30px;
        }
        
        .login-header h1 {
            font-size: 2rem;
        }
    }
</style>

<div class="login-overlay">
    <div class="login-container">
        {% if error %}
            <div class="error-alert">
                <i class="fas fa-exclamation-triangle"></i>
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        {% for message in app.flashes('oauth_error') %}
            <div class="error-alert">
                <i class="fas fa-exclamation-triangle"></i>
                {{ message }}
            </div>
        {% endfor %}
        
        <div class="login-header">
            <h1>
                <div class="login-icon">
                    <i class="fas fa-user"></i>
                </div>
                Welcome Back
            </h1>
        </div>
        
        <form method="post">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
            
            <div class="form-group">
                <label for="inputEmail">Email Address</label>
                <input 
                    type="email" 
                    value="{{ last_username }}" 
                    name="_username" 
                    id="inputEmail" 
                    class="form-control" 
                    autocomplete="email" 
                    required 
                    placeholder="Enter your email"
                    onfocus="this.style.borderColor='#2d4a2b'"
                    onblur="this.style.borderColor='#e0e0e0'"
                >
            </div>

            <div class="form-group">
                <label for="inputPassword">Password</label>
                <input 
                    type="password" 
                    name="_password" 
                    id="inputPassword" 
                    class="form-control" 
                    autocomplete="current-password" 
                    required 
                    placeholder="Enter your password"
                    onfocus="this.style.borderColor='#2d4a2b'"
                    onblur="this.style.borderColor='#e0e0e0'"
                >
            </div>

            <button type="submit" class="btn-login">
                Sign In
            </button>

            <a href="{{ path('connect_google_start') }}" class="btn-google">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
              </svg>
              Sign in with Google
            </a>

        </form>
        
        <div class="register-link">
            <p>Don't have an account?</p>
            <a href="{{ path('app_register') }}">
                Create Account
            </a>
        </div>
    </div>
</div>
{% endblock %}
