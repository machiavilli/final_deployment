{% extends 'base.html.twig' %}

{% block title %}Add New Product - MVLLI{% endblock %}

{% block body %}
<div class="form-wrapper">
    <div class="form-card">
        <h1>Add New Product</h1>

        <div class="form-body">
            {{ form_start(form, {'attr': {'enctype': 'multipart/form-data'}}) }}

            <div class="form-group">
                {{ form_label(form.name) }}
                {{ form_widget(form.name) }}
                {{ form_errors(form.name) }}
            </div>

            <div class="form-group">
                {{ form_label(form.price) }}
                {{ form_widget(form.price) }}
                {{ form_errors(form.price) }}
            </div>

            <div class="form-group">
                {{ form_label(form.description) }}
                {{ form_widget(form.description) }}
                {{ form_errors(form.description) }}
            </div>

            <!-- ✅ Fixed Image Upload Section -->
            <div class="form-group">
                <label for="product_image" class="custom-file-label">📸 Upload Product Image</label>
                {{ form_widget(form.image, {'attr': {'class': 'custom-file-input'}}) }}
                {{ form_errors(form.image) }}
            </div>

            <!-- ✅ Category Field -->
            <div class="form-group">
                {{ form_label(form.category) }}
                {{ form_widget(form.category) }}
                {{ form_errors(form.category) }}
            </div>

            <!-- ✅ Stock Field -->
            <div class="form-group">
                {{ form_label(form.stock) }}
                {{ form_widget(form.stock) }}
                {{ form_errors(form.stock) }}
            </div>

            <div class="form-actions">
                <button class="btn submit">💾 Save Product</button>
            </div>

            {{ form_end(form) }}
        </div>

        <div class="form-actions">
            <a href="{{ path('app_product_index') }}" class="btn back">← Back to List</a>
        </div>
    </div>
</div>
{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    .form-wrapper {
        display: flex;
        justify-content: center;
        align-items: flex-start;
        padding: 40px 20px;
    }

    .form-card {
        background: white;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(45, 74, 43, 0.15);
        max-width: 850px;
        width: 100%;
        padding: 50px 60px;
        animation: fadeIn 0.6s ease-in-out;
    }

    .form-card h1 {
        text-align: center;
        font-size: 2rem;
        color: #1a1a1a;
        margin-bottom: 30px;
        font-weight: 700;
        font-family: var(--font-serif, 'Playfair Display', serif);
    }

    .form-group {
        margin-bottom: 18px;
    }

    label {
        font-weight: 600;
        color: #1a1a1a;
        margin-bottom: 5px;
        display: block;
    }

    input[type="text"],
    input[type="number"],
    textarea,
    select {
        width: 100%;
        padding: 12px 15px;
        border: 2px solid rgba(45, 74, 43, 0.2);
        border-radius: 12px;
        background-color: white;
        font-family: var(--font-sans, 'Inter', sans-serif);
        transition: all 0.3s ease;
    }

    /* Custom File Upload Styling */
    .custom-file-input {
        width: 100%;
        padding: 12px 15px;
        border: 2px dashed rgba(45, 74, 43, 0.3);
        border-radius: 12px;
        background-color: rgba(45, 74, 43, 0.02);
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .custom-file-input:hover {
        border-color: #2d4a2b;
        background-color: rgba(45, 74, 43, 0.05);
    }

    .custom-file-label {
        font-weight: 600;
        color: #1a1a1a;
        display: block;
        margin-bottom: 8px;
    }

    input:focus,
    textarea:focus,
    select:focus {
        border-color: #2d4a2b;
        background-color: white;
        box-shadow: 0 0 8px rgba(45, 74, 43, 0.2);
        outline: none;
    }

    select {
        appearance: none;
        background-image: url("data:image/svg+xml;charset=UTF-8,%3Csvg width='10' height='6' viewBox='0 0 10 6' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath fill='%23666666' d='M0 0l5 6 5-6z'/%3E%3C/svg%3E");
        background-repeat: no-repeat;
        background-position: right 12px center;
        background-size: 10px;
    }

    button {
        background: linear-gradient(135deg, #2d4a2b 0%, #3a5a40 100%);
        color: white !important;
        font-weight: 600;
        font-size: 1rem;
        border: none;
        border-radius: 25px;
        padding: 12px 30px;
        cursor: pointer;
        transition: all 0.3s ease;
        margin-top: 10px;
        box-shadow: 0 4px 10px rgba(45, 74, 43, 0.25);
    }

    button:hover {
        background: linear-gradient(135deg, #3a5a40 0%, #2d4a2b 100%);
        transform: translateY(-2px);
        box-shadow: 0 6px 15px rgba(45, 74, 43, 0.35);
    }

    .form-actions {
        display: flex;
        justify-content: center;
        margin-top: 35px;
    }

    .btn.back {
        background-color: #f5f5f5;
        color: #1a1a1a;
        font-weight: 600;
        padding: 12px 28px;
        border-radius: 25px;
        text-decoration: none;
        border: 2px solid rgba(45, 74, 43, 0.2);
        transition: all 0.3s ease;
    }

    .btn.back:hover {
        background-color: #e0e0e0;
        border-color: #2d4a2b;
        transform: translateY(-2px);
    }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @media (max-width: 768px) {
        .form-card {
            padding: 30px 25px;
        }

        button {
            width: 100%;
        }

        .btn.back {
            width: 100%;
            text-align: center;
        }
    }
</style>
{% endblock %}
