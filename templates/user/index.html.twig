{% extends 'base.html.twig' %}

{% block title %}User Management - MVLLI{% endblock %}

{% block body %}
<style>
    @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@400;500;600;700&display=swap');
    
    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }
    
    body {
        background: #f5f5f5;
        font-family: 'DM Sans', sans-serif;
        color: #2d4a2b;
        line-height: 1.6;
    }
    
    .user-management-container {
        padding: 40px 30px;
        max-width: 1400px;
        margin: 0 auto;
        background: #f5f5f5;
        min-height: calc(100vh - 80px);
    }
    
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }
    
    .page-title {
        font-family: 'Playfair Display', serif;
        font-size: 2.2rem;
        font-weight: 700;
        color: #2d4a2b;
        margin: 0;
    }
    
    .add-user-btn {
        padding: 14px 28px;
        background: linear-gradient(135deg, #2d4a2b 0%, #3a5a40 100%);
        color: white;
        text-decoration: none;
        border-radius: 10px;
        font-weight: 600;
        display: inline-block;
        box-shadow: 0 4px 15px rgba(45, 74, 43, 0.3);
        transition: all 0.3s ease;
        font-family: 'DM Sans', sans-serif;
    }
    
    .add-user-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(45, 74, 43, 0.4);
        background: linear-gradient(135deg, #3a5a40 0%, #4a6b50 100%);
    }
    
    .flash-message {
        background: #d4edda;
        color: #155724;
        padding: 12px;
        border-radius: 8px;
        margin-bottom: 20px;
        border-left: 4px solid #28a745;
        font-family: 'DM Sans', sans-serif;
    }
    
    .users-table {
        background: white;
        border-radius: 16px;
        padding: 28px;
        border: 1px solid #e0e0e0;
        box-shadow: 0 2px 4px rgba(45, 74, 43, 0.1);
        overflow: hidden;
    }
    
    .table-container {
        overflow-x: auto;
    }
    
    .data-table {
        width: 100%;
        border-collapse: collapse;
        font-family: 'DM Sans', sans-serif;
    }
    
    .data-table th {
        padding: 16px;
        text-align: left;
        color: #2d4a2b;
        font-weight: 600;
        font-family: 'DM Sans', sans-serif;
        background: #f8f9fa;
        border-bottom: 2px solid #e0e0e0;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-size: 0.85rem;
    }
    
    .data-table td {
        padding: 16px;
        border-bottom: 1px solid #e0e0e0;
        font-family: 'DM Sans', sans-serif;
        color: #333333;
    }
    
    .data-table tr:last-child td {
        border-bottom: none;
    }
    
    .data-table tr:hover {
        background: #f5f5f5;
    }
    
    .role-badge {
        padding: 6px 12px;
        border-radius: 6px;
        font-size: 0.85rem;
        font-weight: 600;
        font-family: 'DM Sans', sans-serif;
    }
    
    .role-badge.admin {
        background: #2d4a2b;
        color: white;
    }
    
    .role-badge.staff {
        background: #6b8c6a;
        color: white;
    }
    
    .status-badge {
        padding: 6px 12px;
        border-radius: 6px;
        font-size: 0.85rem;
        font-weight: 600;
        font-family: 'DM Sans', sans-serif;
    }
    
    .status-badge.active {
        background: #3a5a40;
        color: white;
    }
    
    .status-badge.inactive {
        background: #999999;
        color: white;
    }
    
    .action-buttons {
        display: flex;
        gap: 8px;
    }
    
    .action-btn {
        padding: 6px 12px;
        background: #f5f5f5;
        border: 1px solid #e0e0e0;
        border-radius: 6px;
        color: #2d4a2b;
        text-decoration: none;
        font-size: 0.85rem;
        font-weight: 500;
        font-family: 'DM Sans', sans-serif;
        transition: all 0.2s ease;
    }
    
    .action-btn:hover {
        background: #2d4a2b;
        color: white;
    }
    
    .empty-state {
        text-align: center;
        padding: 60px 20px;
        color: #666666;
        font-family: 'DM Sans', sans-serif;
    }
    
    .empty-state i {
        font-size: 2.5rem;
        margin-bottom: 16px;
        opacity: 0.3;
        color: #2d4a2b;
    }
    
    @media (max-width: 768px) {
        .user-management-container {
            padding: 20px;
        }
        
        .page-title {
            font-size: 1.8rem;
        }
        
        .data-table {
            font-size: 0.9rem;
        }
        
        .data-table th,
        .data-table td {
            padding: 12px;
        }
    }
</style>

<div class="user-management-container">
    <div class="page-header">
        <h1 class="page-title">User Management</h1>
        <a href="{{ path('app_user_new') }}" class="add-user-btn">Create New User</a>
    </div>

    {% for message in app.flashes('success') %}
        <div class="flash-message">{{ message }}</div>
    {% endfor %}

    <div class="users-table">
        <div class="table-container">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Username</th>
                        <th>Email</th>
                        <th>Name</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th>Date Created</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for user in users %}
                        <tr>
                            <td>{{ user.username }}</td>
                            <td>{{ user.email }}</td>
                            <td>{{ user.name }}</td>
                            <td>
                                <span class="role-badge {% if 'ROLE_ADMIN' in user.roles %}admin{% elseif 'ROLE_STAFF' in user.roles %}staff{% else %}customer{% endif %}">
                                    {% if 'ROLE_ADMIN' in user.roles %}Admin{% elseif 'ROLE_STAFF' in user.roles %}Staff{% else %}Customer{% endif %}
                                </span>
                            </td>
                            <td>
                                <span class="status-badge {% if user.isActive %}active{% else %}inactive{% endif %}">
                                    {% if user.isActive %}Active{% else %}Inactive{% endif %}
                                </span>
                            </td>
                            <td>{{ user.createdAt|date('Y-m-d') }}</td>
                            <td>
                                <div class="action-buttons">
                                    <a href="{{ path('app_user_show', {'id': user.id}) }}" class="action-btn" title="View">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a href="{{ path('app_user_edit', {'id': user.id}) }}" class="action-btn" title="Edit">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <form method="post" action="{{ path('app_user_toggle_status', {'id': user.id}) }}" style="display: inline;">
                                        <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ user.id) }}">
                                        <button type="submit" class="action-btn" title="Toggle Status">
                                            <i class="fas fa-toggle-{% if user.isActive %}on{% else %}off{% endif %}"></i>
                                        </button>
                                    </form>
                                    <form method="post" action="{{ path('app_user_delete', {'id': user.id}) }}" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this user?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
                                        <button type="submit" style="background: none; border: none; color: #dc3545; cursor: pointer;" title="Delete">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="7" style="padding: 40px; text-align: center; color: #999;">No users found</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}

