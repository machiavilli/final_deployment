{% extends 'base.html.twig' %}

{% block title %}Orders - MVLLI{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <!-- DataTables CSS -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/responsive/2.5.0/css/responsive.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.2/css/buttons.dataTables.min.css">
{% endblock %}

{% block body %}
<style>
    @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@400;500;600;700&display=swap');
    
    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }
    
    body {
        background: #f5f5f5;
        font-family: 'DM Sans', sans-serif;
        color: #2d4a2b;
        line-height: 1.6;
    }
    
    .orders-container {
        padding: 40px 30px;
        max-width: 1400px;
        margin: 0 auto;
        background: #f5f5f5;
        min-height: calc(100vh - 80px);
        animation: fadeIn 0.5s ease-in-out;
    }
    
    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
    
    /* Header Section */
    .orders-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }
    
    .page-title {
        font-family: 'Playfair Display', serif;
        font-size: 2rem;
        font-weight: 700;
        color: #2d4a2b;
        margin: 0;
    }
    
    .export-btn {
        padding: 14px 28px;
        background: linear-gradient(135deg, #2d4a2b 0%, #3a5a40 100%);
        color: white;
        text-decoration: none;
        border-radius: 10px;
        font-weight: 600;
        font-family: 'DM Sans', sans-serif;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(45, 74, 43, 0.3);
    }
    
    .export-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(45, 74, 43, 0.4);
        background: linear-gradient(135deg, #3a5a40 0%, #4a6b50 100%);
    }
    
    .header-actions {
        display: flex;
        gap: 10px;
        align-items: center;
    }
    
    .btn-add {
        background: linear-gradient(135deg, #2d4a2b 0%, #3a5a40 100%);
        color: white;
        padding: 10px 20px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 500;
        font-size: 0.9rem;
        display: flex;
        align-items: center;
        gap: 6px;
        transition: all 0.3s ease;
        box-shadow: 0 3px 10px rgba(139, 94, 60, 0.3);
        border: none;
        cursor: pointer;
    }

    .btn-add:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 16px rgba(139, 94, 60, 0.4);
    }

    /* Stats Overview */
    .orders-stats {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 12px;
        margin-bottom: 20px;
    }

    .stat-box {
        background: white;
        border-radius: 10px;
        padding: 16px;
        box-shadow: 0 2px 10px rgba(139, 94, 60, 0.08);
        border-left: 3px solid;
        transition: all 0.3s ease;
    }

    .stat-box:hover {
        transform: translateY(-2px);
        box-shadow: 0 3px 12px rgba(139, 94, 60, 0.12);
    }

    .stat-box.pending { border-left-color: #FF9800; }
    .stat-box.completed { border-left-color: #4CAF50; }
    .stat-box.cancelled { border-left-color: #F44336; }
    .stat-box.total { border-left-color: #2196F3; }

    .stat-box h3 {
        font-size: 0.75rem;
        color: #8B5E3C;
        margin: 0 0 6px 0;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-weight: 600;
    }

    .stat-box .stat-value {
        font-size: 1.5rem;
        font-weight: 700;
        color: #3E2723;
        margin: 0;
    }

    /* DataTable Container */
    .table-container {
        background: white;
        border-radius: 12px;
        box-shadow: 0 3px 16px rgba(139, 94, 60, 0.08);
        border: 1px solid rgba(139, 94, 60, 0.1);
        overflow: hidden;
        padding: 20px;
    }

    /* DataTables Custom Styling */
    .dataTables_wrapper {
        font-family: 'Poppins', sans-serif !important;
    }

    .dataTables_wrapper .dataTables_length select {
        padding: 6px 12px;
        border: 1px solid rgba(139, 94, 60, 0.2);
        border-radius: 6px;
        font-size: 0.85rem;
        color: #3E2723;
        background: white;
        margin: 0 5px;
    }

    .dataTables_wrapper .dataTables_filter input {
        padding: 8px 14px;
        border: 1px solid rgba(139, 94, 60, 0.2);
        border-radius: 8px;
        font-size: 0.85rem;
        color: #3E2723;
        background: white;
        margin-left: 8px;
    }

    .dataTables_wrapper .dataTables_filter input:focus {
        outline: none;
        border-color: #8B5E3C;
        box-shadow: 0 0 0 2px rgba(139, 94, 60, 0.1);
    }

    /* Table Styles */
    table.dataTable {
        width: 100% !important;
        border-collapse: collapse;
        margin-top: 10px !important;
    }

    table.dataTable thead {
        background: linear-gradient(135deg, #8B5E3C 0%, #A0724E 100%);
        color: white;
    }

    table.dataTable thead th {
        padding: 12px 16px !important;
        text-align: left;
        font-weight: 600;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.4px;
        white-space: nowrap;
        border-bottom: none !important;
    }

    table.dataTable tbody tr {
        border-bottom: 1px solid rgba(139, 94, 60, 0.1);
        transition: all 0.2s ease;
    }

    table.dataTable tbody tr:hover {
        background: rgba(139, 94, 60, 0.03) !important;
    }

    table.dataTable tbody td {
        padding: 12px 16px !important;
        font-size: 0.85rem;
        color: #3E2723;
    }

    /* Order ID Badge */
    .order-id {
        font-weight: 600;
        color: #8B5E3C;
        font-family: 'Courier New', monospace;
        font-size: 0.85rem;
    }

    /* Status Badge */
    .status-badge {
        padding: 4px 10px;
        border-radius: 16px;
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: capitalize;
        display: inline-block;
        white-space: nowrap;
    }

    .status-badge.pending {
        background: #FFF3E0;
        color: #E65100;
    }

    .status-badge.processing {
        background: #E3F2FD;
        color: #1565C0;
    }

    .status-badge.completed {
        background: #E8F5E9;
        color: #2E7D32;
    }

    .status-badge.cancelled {
        background: #FFEBEE;
        color: #C62828;
    }

    .status-badge.delivered {
        background: #F3E5F5;
        color: #6A1B9A;
    }

    /* Price Display */
    .price {
        font-weight: 600;
        color: #2E7D32;
        font-size: 0.85rem;
    }

    /* Action Buttons */
    .action-buttons {
        display: flex;
        gap: 6px;
    }

    .btn-action {
        padding: 5px 10px;
        border-radius: 5px;
        text-decoration: none;
        font-size: 0.75rem;
        font-weight: 500;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        white-space: nowrap;
    }

    .btn-view {
        background: #E3F2FD;
        color: #1565C0;
    }

    .btn-view:hover {
        background: #BBDEFB;
        transform: translateY(-1px);
    }

    .btn-edit {
        background: #FFF3E0;
        color: #E65100;
    }

    .btn-edit:hover {
        background: #FFE0B2;
        transform: translateY(-1px);
    }

    /* DataTables Pagination */
    .dataTables_wrapper .dataTables_paginate .paginate_button {
        padding: 6px 12px !important;
        margin: 0 2px;
        border-radius: 6px !important;
        border: 1px solid rgba(139, 94, 60, 0.2) !important;
        background: white !important;
        color: #6D4C41 !important;
        font-size: 0.85rem;
    }

    .dataTables_wrapper .dataTables_paginate .paginate_button:hover {
        background: #8B5E3C !important;
        color: white !important;
        border-color: #8B5E3C !important;
    }

    .dataTables_wrapper .dataTables_paginate .paginate_button.current {
        background: #8B5E3C !important;
        color: white !important;
        border-color: #8B5E3C !important;
    }

    /* DataTables Info */
    .dataTables_wrapper .dataTables_info {
        font-size: 0.85rem;
        color: #6D4C41;
        padding-top: 10px;
    }

    /* Empty State */
    .empty-state {
        text-align: center;
        padding: 50px 20px;
        color: #8B5E3C;
    }

    .empty-state i {
        font-size: 3rem;
        margin-bottom: 16px;
        opacity: 0.3;
    }

    .empty-state h3 {
        font-size: 1.2rem;
        color: #3E2723;
        margin: 0 0 8px 0;
    }

    .empty-state p {
        margin: 0 0 20px 0;
        font-size: 0.9rem;
        color: #6D4C41;
    }

    /* Responsive */
    @media (max-width: 768px) {
        .orders-container {
            padding: 16px;
        }

        .orders-header h1 {
            font-size: 1.4rem;
        }

        .orders-stats {
            grid-template-columns: repeat(2, 1fr);
        }

        .table-container {
            padding: 12px;
        }
    }

    @media (max-width: 480px) {
        .orders-stats {
            grid-template-columns: 1fr;
        }
    }

    .orders-live-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 0.75rem;
        font-weight: 600;
        color: #2e7d32;
        background: #e8f5e9;
        padding: 6px 12px;
        border-radius: 20px;
        margin-left: 12px;
        vertical-align: middle;
    }

    .orders-live-badge::before {
        content: '';
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #4caf50;
        animation: livePulse 1.5s ease-in-out infinite;
    }

    @keyframes livePulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.35; }
    }

    .orders-live-toast {
        position: fixed;
        top: 24px;
        right: 24px;
        z-index: 9999;
        background: #2d4a2b;
        color: #fff;
        padding: 14px 20px;
        border-radius: 10px;
        font-size: 0.9rem;
        font-weight: 600;
        box-shadow: 0 8px 24px rgba(45, 74, 43, 0.35);
        opacity: 0;
        transform: translateY(-8px);
        transition: opacity 0.3s ease, transform 0.3s ease;
        pointer-events: none;
        max-width: 320px;
    }

    .orders-live-toast--visible {
        opacity: 1;
        transform: translateY(0);
    }

</style>

<div
    class="orders-container"
    id="ordersLiveRoot"
    data-sync-url="{{ path('app_order_sync') }}"
    data-poll-ms="5000"
>
    <div id="ordersLiveToast" class="orders-live-toast" hidden role="status" aria-live="polite"></div>

    <!-- Header -->
    <div class="orders-header">
        <h1>
            <i class="fas fa-shopping-cart"></i> Orders Management
            <span class="orders-live-badge" id="ordersLiveIndicator">Live</span>
        </h1>
        <div class="header-actions">
            <a href="{{ path('app_order_new') }}" class="btn-add">
                <i class="fas fa-plus"></i> New Order
            </a>
        </div>
    </div>

    <!-- Stats Overview -->
    <div class="orders-stats">
        <div class="stat-box total">
            <h3>Total Orders</h3>
            <p class="stat-value" id="statTotal">{{ orders|length }}</p>
        </div>
        <div class="stat-box pending">
            <h3>Pending</h3>
            <p class="stat-value" id="statPending">{{ orders|filter(o => o.status|lower == 'pending')|length }}</p>
        </div>
        <div class="stat-box completed">
            <h3>Completed</h3>
            <p class="stat-value" id="statCompleted">{{ orders|filter(o => o.status|lower == 'completed')|length }}</p>
        </div>
        <div class="stat-box cancelled">
            <h3>Cancelled</h3>
            <p class="stat-value" id="statCancelled">{{ orders|filter(o => o.status|lower == 'cancelled')|length }}</p>
        </div>
    </div>

    <!-- Orders DataTable -->
    <div class="table-container">
        {% if orders|length > 0 %}
            <table id="ordersTable" class="display responsive nowrap" style="width:100%">
                <thead>
                    <tr>
                        <th>Order #</th>
                        <th>Customer</th>
                        <th>Product</th>
                        <th>Qty</th>
                        <th>Total</th>
                        <th>Payment</th>
                        <th>Status</th>
                        <th>Source</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for order in orders %}
                    <tr>
                        <td>
                            <span class="order-id">{{ order.orderNumber ?? ('#' ~ order.id) }}</span>
                        </td>
                        <td>{% if order.customer %}{{ order.customer.name }}{% else %}N/A{% endif %}</td>
                        <td>{{ order.productName }}</td>
                        <td>{{ order.quantity|round }}</td>
                        <td><span class="price">₱{{ order.lineTotal|number_format(2) }}</span></td>
                        <td>
                            <span class="status-badge {{ order.paymentStatus|default('pending')|lower }}">
                                {{ order.paymentStatusLabel }}
                            </span>
                            <br><small>{{ order.paymentMethodLabel }}</small>
                        </td>
                        <td>
                            <span class="status-badge {{ order.status|lower }}">
                                {{ order.status }}
                            </span>
                        </td>
                        <td>{{ order.orderSource == 'website' ? 'Website' : 'Manual' }}</td>
                        <td data-order="{{ order.orderDate|date('Y-m-d') }}">{{ order.orderDate|date('M d, Y') }}</td>
                        <td>
                            <div class="action-buttons">
                                <a href="{{ path('app_order_show', {'id': order.id}) }}" class="btn-action btn-view">
                                    <i class="fas fa-eye"></i> 
                                </a>
                                <a href="{{ path('app_order_edit', {'id': order.id}) }}" class="btn-action btn-edit">
                                    <i class="fas fa-edit"></i> 
                                </a>
                            </div>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        {% else %}
            <div class="empty-state">
                <i class="fas fa-shopping-cart"></i>
                <h3>No Orders Yet</h3>
                <p>Start by creating your first order</p>
                <a href="{{ path('app_order_new') }}" class="btn-add">
                    <i class="fas fa-plus"></i> Create First Order
                </a>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <!-- DataTables JS -->
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/responsive/2.5.0/js/dataTables.responsive.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.2/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.html5.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.print.min.js"></script>
    
    <script>
        // Prevent DataTables from showing browser alert() on row sync issues
        $.fn.dataTable.ext.errMode = 'none';

        $(document).ready(function() {
            $('#ordersTable').DataTable({
                responsive: true,
                pageLength: 10,
                lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                order: [[8, 'desc']], // Sort by Date descending
                columnDefs: [
                    { orderable: false, targets: 9 } // Disable sorting on Actions column
                ],
                language: {
                    search: "Search Orders:",
                    lengthMenu: "Show _MENU_ orders",
                    info: "Showing _START_ to _END_ of _TOTAL_ orders",
                    infoEmpty: "No orders available",
                    infoFiltered: "(filtered from _MAX_ total orders)",
                    zeroRecords: "No matching orders found",
                    paginate: {
                        first: "First",
                        last: "Last",
                        next: "Next",
                        previous: "Previous"
                    }
                },
                dom: '<"top"lf>rt<"bottom"ip><"clear">',
                initComplete: function() {
                    console.log('DataTable initialized successfully');
                    if (typeof window.initOrdersLiveRefresh === 'function') {
                        window.initOrdersLiveRefresh();
                    }
                }
            });
        });

        /**
         * Polls /order/sync every 5s — updates table when a customer checks out on mobile.
         */
        window.initOrdersLiveRefresh = function() {
            const root = document.getElementById('ordersLiveRoot');
            if (!root || !$.fn.DataTable.isDataTable('#ordersTable')) {
                return;
            }

            const syncUrl = root.dataset.syncUrl;
            const pollMs = parseInt(root.dataset.pollMs || '5000', 10);
            let lastVersion = null;
            let isRefreshing = false;
            const table = $('#ordersTable').DataTable();
            const toastEl = document.getElementById('ordersLiveToast');

            function showToast(message) {
                if (!toastEl) return;
                toastEl.textContent = message;
                toastEl.hidden = false;
                toastEl.classList.add('orders-live-toast--visible');
                clearTimeout(window._ordersLiveToastTimer);
                window._ordersLiveToastTimer = setTimeout(function() {
                    toastEl.classList.remove('orders-live-toast--visible');
                    setTimeout(function() {
                        toastEl.hidden = true;
                    }, 300);
                }, 4500);
            }

            function escapeHtml(text) {
                const div = document.createElement('div');
                div.textContent = text ?? '';
                return div.innerHTML;
            }

            function updateStats(stats) {
                if (!stats) return;
                const map = {
                    statTotal: stats.total,
                    statPending: stats.pending,
                    statCompleted: stats.completed,
                    statCancelled: stats.cancelled,
                };
                Object.keys(map).forEach(function(id) {
                    const el = document.getElementById(id);
                    if (el) el.textContent = map[id];
                });
            }

            function cell(value) {
                return value == null ? '' : String(value);
            }

            function updateTable(orders) {
                const currentPage = table.page();
                const currentSearch = table.search();
                const pageLength = table.page.len();

                table.clear();

                const rows = orders.map(function(order) {
                    return [
                        '<span class="order-id">' + escapeHtml(cell(order.orderNumber)) + '</span>',
                        escapeHtml(cell(order.customerName)),
                        escapeHtml(cell(order.productName)),
                        cell(order.quantity),
                        '<span class="price">' + escapeHtml(cell(order.lineTotalFormatted)) + '</span>',
                        '<span class="status-badge ' + escapeHtml(cell(order.paymentStatus)) + '">' + escapeHtml(cell(order.paymentStatusLabel)) + '</span><br><small>' + escapeHtml(cell(order.paymentMethodLabel)) + '</small>',
                        '<span class="status-badge ' + escapeHtml(cell(order.status)) + '">' + escapeHtml(cell(order.statusLabel)) + '</span>',
                        escapeHtml(cell(order.orderSource)),
                        '<span data-order="' + escapeHtml(cell(order.orderDate)) + '">' + escapeHtml(cell(order.orderDateLabel)) + '</span>',
                        '<div class="action-buttons"><a href="' + cell(order.showUrl) + '" class="btn-action btn-view"><i class="fas fa-eye"></i></a><a href="' + cell(order.editUrl) + '" class="btn-action btn-edit"><i class="fas fa-edit"></i></a></div>',
                    ];
                });

                table.rows.add(rows);
                table.page.len(pageLength);
                table.search(currentSearch);
                table.order([[8, 'desc']]);
                table.draw(false);
                if (typeof currentPage === 'number') {
                    table.page(currentPage).draw(false);
                }
            }

            async function poll() {
                if (isRefreshing) return;
                isRefreshing = true;
                try {
                    const response = await fetch(syncUrl, {
                        credentials: 'same-origin',
                        headers: { Accept: 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
                    });
                    if (!response.ok) return;
                    const payload = await response.json();
                    if (payload.version === lastVersion) return;

                    const isFirst = lastVersion === null;
                    lastVersion = payload.version;

                    updateStats(payload.stats);

                    // Skip table rewrite on first poll — page already has correct rows from Twig
                    if (!isFirst) {
                        updateTable(payload.orders);
                        const latest = payload.orders[0];
                        const label = latest
                            ? 'New order ' + (latest.orderNumber || '') + ' — list updated'
                            : 'New customer order — list updated';
                        showToast(label.trim());
                    }
                } catch (e) {
                    console.warn('[OrdersLive] sync failed', e);
                } finally {
                    isRefreshing = false;
                }
            }

            poll();
            setInterval(poll, pollMs);
        };
    </script>
{% endblock %}