{% extends 'base_landing.html.twig' %}

{% block title %}Order Confirmed - MVLLI{% endblock %}

{% block body %}
<style>
    .confirmation-container {
        max-width: 560px;
        margin: 80px auto;
        padding: 40px;
        background: white;
        border-radius: 16px;
        box-shadow: 0 12px 40px rgba(45, 74, 43, 0.12);
        text-align: center;
        font-family: 'DM Sans', sans-serif;
    }
    .confirmation-container h1 {
        color: #2d4a2b;
        font-size: 1.8rem;
        margin-bottom: 12px;
    }
    .order-number {
        display: inline-block;
        background: #f0f4ef;
        color: #2d4a2b;
        padding: 10px 18px;
        border-radius: 8px;
        font-weight: 700;
        margin: 16px 0 24px;
        font-family: monospace;
    }
    .confirmation-actions a {
        display: inline-block;
        margin: 8px;
        padding: 12px 24px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
    }
    .btn-primary {
        background: #2d4a2b;
        color: white;
    }
    .btn-secondary {
        background: #f5f5f5;
        color: #2d4a2b;
    }
</style>

<div class="confirmation-container">
    <h1>Thank you for your order!</h1>
    <p>Your order has been placed and will appear in our system for processing.</p>
    <div class="order-number">{{ orderNumber }}</div>
    <p>Save this order number for your records. Our team will update your order and payment status.</p>
    <div class="confirmation-actions">
        <a href="{{ path('app_home') }}" class="btn-primary">Continue Shopping</a>
        <a href="{{ path('cart_view') }}" class="btn-secondary">View Cart</a>
    </div>
</div>
{% endblock %}
