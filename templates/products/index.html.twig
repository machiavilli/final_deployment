{% extends 'base_landing.html.twig' %}

{% block title %}Our Products - MVLLI{% endblock %}

{% block body %}
<style>
    :root {
        /* MVLLI Color Palette */
        --black: #000000;
        --black-light: #1a1a1a;
        --dark-green: #2d4a2b;
        --green-light: #3a5a40;
        --green-medium: #4a6b50;
        --white: #ffffff;
        --gray-light: #f5f5f5;
        --gray-medium: #8a8a8a;
        
        /* Typography */
        --font-heading: 'Playfair Display', serif;
        --font-body: 'DM Sans', sans-serif;
        
        /* Transitions */
        --transition-smooth: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    * { 
        box-sizing: border-box; 
        margin: 0; 
        padding: 0;
    }

    body {
        background: var(--black);
        font-family: var(--font-body);
        color: var(--white);
        overflow-x: hidden;
    }

    .products-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 24px;
    }

    /* ── HERO SECTION ───────────────────────── */
    .products-hero {
        position: relative;
        background: linear-gradient(135deg, var(--dark-green), var(--black));
        min-height: 500px;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 80px 24px;
        overflow: hidden;
        margin-bottom: 80px;
    }

    .hero-content {
        text-align: center;
        max-width: 800px;
        position: relative;
        z-index: 1;
    }

    .hero-badge {
        display: inline-block;
        font-size: 0.8rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--green-light);
        background: rgba(58, 90, 64, 0.1);
        padding: 8px 16px;
        border: 1px solid var(--green-light);
        border-radius: 8px;
        margin-bottom: 24px;
    }

    .hero-title {
        font-family: var(--font-heading);
        font-size: clamp(2.5rem, 5vw, 4rem);
        font-weight: 700;
        color: var(--white);
        margin: 0 0 24px 0;
        line-height: 1.1;
    }

    .hero-subtitle {
        font-size: 1.1rem;
        color: var(--gray-light);
        line-height: 1.6;
        max-width: 600px;
        margin: 0 auto;
    }

    /* ── PRODUCTS GRID ───────────────────────── */
    .products-body {
        padding: 0 0 80px;
    }

    .products-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 40px;
    }

    /* ── PRODUCT CARD ────────────────────────── */
    .product-card {
        background: var(--white);
        border-radius: 20px;
        overflow: hidden;
        transition: var(--transition-smooth);
        display: flex;
        flex-direction: column;
        position: relative;
        border: 1px solid rgba(58, 90, 64, 0.1);
    }

    .product-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 40px rgba(45, 74, 26, 0.3);
        border-color: var(--green-light);
    }

    .product-image {
        width: 100%;
        height: 300px;
        background: linear-gradient(135deg, var(--dark-green), var(--black));
        position: relative;
        overflow: hidden;
    }

    .product-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.6s ease;
    }

    .product-card:hover .product-image img {
        transform: scale(1.05);
    }

    .product-content {
        padding: 32px;
        display: flex;
        flex-direction: column;
        gap: 20px;
        flex: 1;
    }

    .product-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 16px;
    }

    .product-title {
        font-family: var(--font-heading);
        font-size: 1.4rem;
        font-weight: 700;
        color: var(--black);
        margin: 0;
        line-height: 1.2;
        flex: 1;
    }

    .product-price {
        font-family: var(--font-heading);
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--dark-green);
        background: var(--gray-light);
        padding: 8px 16px;
        border-radius: 12px;
        white-space: nowrap;
        flex-shrink: 0;
    }

    .product-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        padding-bottom: 16px;
        border-bottom: 1px solid var(--gray-light);
    }

    .stock-status {
        font-weight: 600;
        font-size: 0.8rem;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        padding: 6px 12px;
        border-radius: 20px;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .in-stock {
        background: var(--green-light);
        color: var(--white);
    }

    .out-of-stock {
        background: var(--gray-medium);
        color: var(--white);
    }

    .product-description {
        color: var(--gray-medium);
        font-size: 1rem;
        line-height: 1.6;
        margin: 0;
        flex: 1;
    }

    .product-actions {
        margin-top: auto;
        padding-top: 16px;
    }

    .btn-product {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        width: 100%;
        padding: 16px;
        background: var(--dark-green);
        color: var(--white);
        text-decoration: none;
        border-radius: 12px;
        font-weight: 600;
        font-size: 0.95rem;
        transition: var(--transition-smooth);
        font-family: var(--font-body);
    }

    .btn-product:hover {
        background: var(--green-medium);
        transform: translateY(-2px);
    }

    /* ── EMPTY STATE ───────────────────────── */
    .no-products {
        grid-column: 1 / -1;
        background: var(--black-light);
        border-radius: 20px;
        border: 2px solid var(--dark-green);
        padding: 80px 32px;
        text-align: center;
    }

    .no-products i {
        font-size: 3rem;
        color: var(--green-light);
        display: block;
        margin-bottom: 20px;
    }

    .no-products h3 {
        font-family: var(--font-heading);
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--white);
        margin: 0 0 12px;
    }

    .no-products p {
        font-size: 1rem;
        color: var(--gray-light);
        margin: 0;
    }

    /* ── RESPONSIVE ───────────────────────── */
    @media (max-width: 768px) {
        .products-hero {
            padding: 60px 20px;
            min-height: 400px;
        }
        
        .hero-title {
            font-size: 2rem;
        }
        
        .products-grid {
            grid-template-columns: 1fr;
            gap: 24px;
        }
        
        .product-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 24px rgba(45, 74, 26, 0.2);
        }
    }
</style>

<div class="products-container">
    <!-- HERO SECTION -->
    <header class="products-hero">
        <div class="hero-content">
            <div class="hero-badge">Our Collection</div>
            <h1 class="hero-title">Discover <em>Style</em></h1>
            <p class="hero-subtitle">Curated fashion pieces that define your unique identity and elevate your wardrobe.</p>
        </div>
    </header>

    <!-- PRODUCTS GRID -->
    <div class="products-body">
        <main class="products-grid">
            {% for product in products %}
                <article class="product-card">
                    <div class="product-image">
                        {% if product_image_url(product.image) %}
                            <img src="{{ product_image_url(product.image) }}" alt="{{ product.name }}">
                        {% else %}
                            <div style="display: flex; align-items: center; justify-content: center; height: 100%; color: var(--gray-light);">
                                <i class="fas fa-tshirt" style="font-size: 2rem;"></i>
                            </div>
                        {% endif %}
                    </div>

                    <div class="product-content">
                        <div class="product-header">
                            <h2 class="product-title">{{ product.name }}</h2>
                            <div class="product-price">₱{{ product.price|number_format(2) }}</div>
                        </div>

                        <div class="product-meta">
                            <div class="stock-status {% if product.stock > 0 %}in-stock{% else %}out-of-stock{% endif %}">
                                {% if product.stock > 0 %}
                                    <i class="fas fa-check"></i> In Stock ({{ product.stock }})
                                {% else %}
                                    <i class="fas fa-times"></i> Out of Stock
                                {% endif %}
                            </div>
                        </div>

                        {% if product.description %}
                            <p class="product-description">{{ product.description }}</p>
                        {% endif %}

                        <div class="product-actions">
                            <form action="{{ path('cart_add', {'id': product.id}) }}" method="POST">
                                <input type="hidden" name="quantity" value="1">
                                <button type="submit" class="btn-product">
                                    <i class="fas fa-shopping-bag"></i> Add to Cart
                                </button>
                            </form>
                        </div>
                    </div>
                </article>
            {% else %}
                <div class="no-products">
                    <h3>No products found</h3>
                    <p>Check back soon for new arrivals or explore our collections.</p>
                </div>
            {% endfor %}
        </main>
    </div>
</div>
{% endblock %}