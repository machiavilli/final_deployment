{% extends 'base.html.twig' %}

{% block title %}Dashboard - MVLLI Admin{% endblock %}

{% block body %}
<style>
    @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@400;500;600;700&display=swap');

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body {
        background: #f5f5f5;
        font-family: 'DM Sans', sans-serif;
        color: #2d4a2b;
        line-height: 1.6;
    }

    .dashboard-container {
        padding: 40px 30px;
        max-width: 1400px;
        margin: 0 auto;
        background: #f5f5f5;
        min-height: calc(100vh - 80px);
    }

    /* Header */
    .dashboard-header {
        margin-bottom: 50px;
    }

    .dashboard-header h1 {
        font-family: 'Playfair Display', serif;
        font-size: 1.8rem;
        font-weight: 700;
        color: #2d4a2b;
        margin: 0 0 8px 0;
        letter-spacing: -0.5px;
    }

    .dashboard-header p {
        font-size: 0.95rem;
        color: #666666;
        margin: 0;
        font-weight: 400;
    }

    /* Stats Grid - Minimal Cards */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 24px;
        margin-bottom: 50px;
    }

    .stat-card {
        background: white;
        border-radius: 12px;
        padding: 28px;
        border: 1px solid #e0e0e0;
        transition: all 0.2s ease;
        box-shadow: 0 2px 4px rgba(45, 74, 43, 0.1);
    }

    .stat-card:hover {
        border-color: #2d4a2b;
        box-shadow: 0 4px 12px rgba(45, 74, 43, 0.15);
        transform: translateY(-2px);
    }

    .stat-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 20px;
    }

    .stat-label {
        font-size: 0.85rem;
        color: #666666;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .stat-icon {
        width: 40px;
        height: 40px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        background: #2d4a2b;
        color: white;
    }

    .stat-value {
        font-family: 'Playfair Display', serif;
        font-size: 2rem;
        font-weight: 700;
        color: #2d4a2b;
        margin: 0;
        letter-spacing: -1px;
    }

    .stat-change {
        font-size: 0.8rem;
        color: #666666;
        margin-top: 12px;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .stat-change i {
        font-size: 0.7rem;
    }

    .stat-change.positive {
        color: #3a5a40;
    }

    /* Section Titles */
    .section-title {
        font-family: 'Playfair Display', serif;
        font-size: 1.2rem;
        font-weight: 700;
        color: #2d4a2b;
        margin-bottom: 24px;
        letter-spacing: -0.3px;
    }

    /* Charts Section */
    .charts-section {
        margin-bottom: 50px;
    }

    .charts-grid {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 24px;
        margin-bottom: 24px;
    }

    .chart-card {
        background: white;
        border-radius: 12px;
        padding: 28px;
        border: 1px solid #e0e0e0;
        box-shadow: 0 2px 4px rgba(45, 74, 43, 0.1);
    }

    .chart-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
        padding-bottom: 16px;
        border-bottom: 1px solid #e0e0e0;
    }

    .chart-title {
        font-family: 'Playfair Display', serif;
        font-size: 0.95rem;
        font-weight: 700;
        color: #2d4a2b;
        margin: 0;
    }

    .chart-period {
        font-size: 0.8rem;
        color: #666666;
        font-weight: 500;
    }

    .chart-container {
        position: relative;
        height: 280px;
    }

    /* Quick Actions - Minimal */
    .quick-actions {
        margin-bottom: 50px;
    }

    .actions-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 16px;
    }

    .action-card {
        background: white;
        border-radius: 12px;
        padding: 20px;
        text-decoration: none;
        color: inherit;
        border: 1px solid #e0e0e0;
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        gap: 16px;
        box-shadow: 0 2px 4px rgba(45, 74, 43, 0.1);
    }

    .action-card:hover {
        border-color: #2d4a2b;
        box-shadow: 0 4px 12px rgba(45, 74, 43, 0.15);
        transform: translateY(-2px);
    }

    .action-icon {
        width: 40px;
        height: 40px;
        border-radius: 8px;
        background: #2d4a2b;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        flex-shrink: 0;
    }

    .action-content h3 {
        font-family: 'Playfair Display', serif;
        font-size: 0.9rem;
        font-weight: 700;
        color: #2d4a2b;
        margin: 0 0 4px 0;
    }

    .action-content p {
        font-size: 0.8rem;
        color: #999;
        margin: 0;
    }

    /* Recent Activity - Minimal */
    .recent-activity {
        background: white;
        border-radius: 12px;
        padding: 28px;
        border: 1px solid #e0e0e0;
        box-shadow: 0 2px 4px rgba(45, 74, 43, 0.1);
    }

    .activity-item {
        padding: 16px 0;
        border-bottom: 1px solid #e0e0e0;
        display: flex;
        align-items: center;
        gap: 16px;
        transition: background 0.2s ease;
    }

    .activity-item:last-child {
        border-bottom: none;
    }

    .activity-item:hover {
        background: #f5f5f5;
        margin: 0 -12px;
        padding-left: 12px;
        padding-right: 12px;
        border-radius: 8px;
    }

    .activity-icon {
        width: 36px;
        height: 36px;
        border-radius: 8px;
        background: #2d4a2b;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 0.9rem;
        flex-shrink: 0;
    }

    .activity-content {
        flex: 1;
    }

    .activity-content p {
        margin: 0 0 4px 0;
        color: #2d4a2b;
        font-weight: 500;
        font-size: 0.9rem;
    }

    .activity-time {
        font-size: 0.8rem;
        color: #999;
    }

    /* Empty State */
    .empty-state {
        text-align: center;
        padding: 60px 20px;
        color: #999;
    }

    .empty-state i {
        font-size: 2.5rem;
        margin-bottom: 16px;
        opacity: 0.3;
    }

    .empty-state p {
        margin: 0;
        font-size: 0.9rem;
    }

    /* Responsive */
    @media (max-width: 1024px) {
        .charts-grid {
            grid-template-columns: 1fr;
        }
    }

    @media (max-width: 768px) {
        .dashboard-container {
            padding: 24px 20px;
        }

        .dashboard-header h1 {
            font-size: 1.5rem;
        }

        .stats-grid {
            grid-template-columns: 1fr;
            gap: 16px;
        }

        .stat-value {
            font-size: 1.75rem;
        }

        .actions-grid {
            grid-template-columns: 1fr;
        }

        .chart-container {
            height: 240px;
        }

        .charts-grid {
            gap: 16px;
        }
    }

    @media (max-width: 480px) {
        .dashboard-container {
            padding: 20px 16px;
        }

        .stat-card,
        .chart-card,
        .recent-activity {
            padding: 20px;
        }
    }

    .dashboard-live-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 0.75rem;
        font-weight: 600;
        color: #2e7d32;
        background: #e8f5e9;
        padding: 6px 12px;
        border-radius: 20px;
        margin-left: 12px;
        vertical-align: middle;
    }

    .dashboard-live-badge::before {
        content: '';
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #4caf50;
        animation: dashboardLivePulse 1.5s ease-in-out infinite;
    }

    @keyframes dashboardLivePulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.35; }
    }

    .dashboard-live-toast {
        position: fixed;
        top: 24px;
        right: 24px;
        z-index: 9999;
        background: #2d4a2b;
        color: #fff;
        padding: 14px 20px;
        border-radius: 10px;
        font-size: 0.9rem;
        font-weight: 600;
        box-shadow: 0 8px 24px rgba(45, 74, 43, 0.35);
        opacity: 0;
        transform: translateY(-8px);
        transition: opacity 0.3s ease, transform 0.3s ease;
        pointer-events: none;
        max-width: 340px;
    }

    .dashboard-live-toast--visible {
        opacity: 1;
        transform: translateY(0);
    }
</style>

<div
    class="dashboard-container"
    id="dashboardLiveRoot"
    data-sync-url="{{ path('app_admin_dashboard_sync') }}"
    data-poll-ms="5000"
>
    <div id="dashboardLiveToast" class="dashboard-live-toast" hidden role="status" aria-live="polite"></div>

    <!-- Header -->
    <div class="dashboard-header">
        <h1>
            MVLLI Dashboard
            <span class="dashboard-live-badge" id="dashboardLiveIndicator">Live</span>
        </h1>
        <p>Welcome back! Here's an overview of your fashion store.</p>
    </div>

    <!-- Stats Cards -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-header">
                <span class="stat-label">Total Products</span>
                <div class="stat-icon">
                    <i class="fas fa-box"></i>
                </div>
            </div>
            <div class="stat-value" id="statProducts">{{ total_products|default(0) }}</div>
            <div class="stat-change">
                <span>Active in catalog</span>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-header">
                <span class="stat-label">Total Orders</span>
                <div class="stat-icon">
                    <i class="fas fa-shopping-cart"></i>
                </div>
            </div>
            <div class="stat-value" id="statOrders">{{ total_orders|default(0) }}</div>
            <div class="stat-change" id="statOrdersChange">
            {% if orders_change_pct is not null %}
                <i class="fas fa-arrow-{% if orders_change_pct >= 0 %}up{% else %}down{% endif %}"></i>
                <span>{{ orders_change_pct|abs }}% vs prior 30 days</span>
            {% else %}
                <span>Last 30 days</span>
            {% endif %}
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-header">
                <span class="stat-label">Total Customers</span>
                <div class="stat-icon">
                    <i class="fas fa-user-friends"></i>
                </div>
            </div>
            <div class="stat-value" id="statCustomers">{{ total_customers|default(0) }}</div>
            <div class="stat-change" id="statCustomersChange">
            {% if customers_change_pct is not null %}
                <i class="fas fa-arrow-{% if customers_change_pct >= 0 %}up{% else %}down{% endif %}"></i>
                <span>{{ customers_change_pct|abs }}% new signups vs prior 30 days</span>
            {% else %}
                <span>Registered accounts</span>
            {% endif %}
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-header">
                <span class="stat-label">Revenue</span>
                <div class="stat-icon">
                    <i class="fas fa-dollar-sign"></i>
                </div>
            </div>
            <div class="stat-value" id="statRevenue">₱{{ total_revenue|default(0)|number_format(2) }}</div>
            <div class="stat-change" id="statRevenueChange">
            {% if revenue_change_pct is not null %}
                <i class="fas fa-arrow-{% if revenue_change_pct >= 0 %}up{% else %}down{% endif %}"></i>
                <span>{{ revenue_change_pct|abs }}% vs prior 30 days</span>
            {% else %}
                <span>All-time order value</span>
            {% endif %}
            </div>
        </div>
    </div>

    <!-- Charts Section -->
    <div class="charts-section">
        <h2 class="section-title">Analytics</h2>
        
        <div class="charts-grid">
            <!-- Sales Chart -->
            <div class="chart-card">
                <div class="chart-header">
                    <h3 class="chart-title">Order Value</h3>
                    <span class="chart-period">Last 7 days (from orders)</span>
                </div>
                <div class="chart-container">
                    <canvas id="salesChart"></canvas>
                </div>
            </div>

            <!-- Category Distribution Chart -->
            <div class="chart-card">
                <div class="chart-header">
                    <h3 class="chart-title">Top Fashion Categories</h3>
                    <span class="chart-period">This Month</span>
                </div>
                <div class="chart-container">
                    <canvas id="categoryChart"></canvas>
                </div>
            </div>
        </div>

        <!-- Revenue Chart -->
        <div class="chart-card">
            <div class="chart-header">
                <h3 class="chart-title">Monthly Revenue</h3>
                <span class="chart-period">Last 6 months (from orders)</span>
            </div>
            <div class="chart-container">
                <canvas id="revenueChart"></canvas>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="quick-actions">
        <h2 class="section-title">Quick Actions</h2>
        <div class="actions-grid">
            <a href="{{ path('app_product_index') }}" class="action-card">
                <div class="action-icon">
                    <i class="fas fa-plus"></i>
                </div>
                <div class="action-content">
                    <h3>Add Product</h3>
                    <p>Create new product listing</p>
                </div>
            </a>

            <a href="{{ path('app_order_index') }}" class="action-card">
                <div class="action-icon">
                    <i class="fas fa-eye"></i>
                </div>
                <div class="action-content">
                    <h3>View Orders</h3>
                    <p>Manage customer orders</p>
                </div>
            </a>

            <a href="{{ path('app_customer_index') }}" class="action-card">
                <div class="action-icon">
                    <i class="fas fa-users"></i>
                </div>
                <div class="action-content">
                    <h3>Customers</h3>
                    <p>View customer list</p>
                </div>
            </a>

            <a href="{{ path('app_category_index') }}" class="action-card">
                <div class="action-icon">
                    <i class="fas fa-tags"></i>
                </div>
                <div class="action-content">
                    <h3>Categories</h3>
                    <p>Manage categories</p>
                </div>
            </a>
        </div>
    </div>

    <!-- Recent Activity -->
    <div class="recent-activity">
        <h2 class="section-title">Recent Activity</h2>
        <div id="recentActivityList">
        {% if recent_activities is defined and recent_activities|length > 0 %}
            {% for activity in recent_activities %}
                <div class="activity-item">
                    <div class="activity-icon">
                        {% if activity.action == 'CREATE' %}
                            <i class="fas fa-plus"></i>
                        {% elseif activity.action == 'UPDATE' %}
                            <i class="fas fa-edit"></i>
                        {% elseif activity.action == 'DELETE' %}
                            <i class="fas fa-trash"></i>
                        {% elseif activity.action == 'LOGIN' %}
                            <i class="fas fa-sign-in-alt"></i>
                        {% elseif activity.action == 'LOGOUT' %}
                            <i class="fas fa-sign-out-alt"></i>
                        {% else %}
                            <i class="fas fa-bell"></i>
                        {% endif %}
                    </div>
                    <div class="activity-content">
                        <p>
                            <strong>{% if activity.user %}{{ activity.user.username }}{% else %}System{% endif %}</strong>
                            - {{ activity.description|default(activity.action ~ ' ' ~ activity.entityType) }}
                        </p>
                        <span class="activity-time">{{ activity.timestamp|date('Y-m-d H:i:s') }}</span>
                    </div>
                </div>
            {% endfor %}
        {% else %}
            <div class="empty-state">
                <i class="fas fa-inbox"></i>
                <p>No recent activity to display</p>
            </div>
        {% endif %}
        </div>
    </div>
</div>

<!-- Chart.js Library -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

<script>
    const categoryPalette = ['#2d4a2b', '#3a5a40', '#4a6b50', '#8b5a3a', '#6b8e23', '#5c7a52'];

    document.addEventListener('DOMContentLoaded', function() {
        const salesChartData = {{ sales_chart|json_encode|raw }};
        const categoryChartData = {{ category_chart|json_encode|raw }};
        const revenueChartData = {{ revenue_chart|json_encode|raw }};

        const chartColors = {
            primary: '#2d4a2b',
            secondary: '#666',
            background: '#f5f5f5',
            grid: '#e5e5e5'
        };

        let salesChartInstance = null;
        let categoryChartInstance = null;
        let revenueChartInstance = null;

        const salesCtx = document.getElementById('salesChart');
        if (salesCtx) {
            salesChartInstance = new Chart(salesCtx, {
                type: 'line',
                data: {
                    labels: salesChartData.labels,
                    datasets: [{
                        label: 'Order value (₱)',
                        data: salesChartData.values,
                        borderColor: chartColors.primary,
                        backgroundColor: 'rgba(45, 74, 43, 0.1)',
                        tension: 0.4,
                        fill: true,
                        borderWidth: 2,
                        pointRadius: 4,
                        pointBackgroundColor: chartColors.primary,
                        pointBorderColor: '#fff',
                        pointBorderWidth: 2,
                        pointHoverRadius: 6
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: false
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: {
                                color: chartColors.grid,
                                borderColor: chartColors.grid
                            },
                            ticks: {
                                color: chartColors.secondary,
                                font: {
                                    size: 11
                                }
                            }
                        },
                        x: {
                            grid: {
                                display: false
                            },
                            ticks: {
                                color: chartColors.secondary,
                                font: {
                                    size: 11
                                }
                            }
                        }
                    }
                }
            });
        }

        // Category Chart (Doughnut Chart)
        const categoryCtx = document.getElementById('categoryChart');
        if (categoryCtx) {
            categoryChartInstance = new Chart(categoryCtx, {
                type: 'doughnut',
                data: {
                    labels: categoryChartData.labels,
                    datasets: [{
                        label: 'Products by category',
                        data: categoryChartData.values,
                        backgroundColor: categoryChartData.labels.map((_, i) => categoryPalette[i % categoryPalette.length]),
                        borderWidth: 2,
                        hoverOffset: 8
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                padding: 12,
                                font: {
                                    size: 11
                                },
                                color: chartColors.secondary
                            }
                        }
                    }
                }
            });
        }

        // Revenue Chart (Bar Chart)
        const revenueCtx = document.getElementById('revenueChart');
        if (revenueCtx) {
            revenueChartInstance = new Chart(revenueCtx, {
                type: 'bar',
                data: {
                    labels: revenueChartData.labels,
                    datasets: [{
                        label: 'Revenue (₱)',
                        data: revenueChartData.values,
                        backgroundColor: chartColors.primary,
                        borderColor: chartColors.primary,
                        borderWidth: 0,
                        borderRadius: 6,
                        hoverBackgroundColor: '#333'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: false
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: {
                                color: chartColors.grid,
                                borderColor: chartColors.grid
                            },
                            ticks: {
                                color: chartColors.secondary,
                                font: {
                                    size: 11
                                },
                                callback: function(value) {
                                    return '₱' + value.toLocaleString();
                                }
                            }
                        },
                        x: {
                            grid: {
                                display: false
                            },
                            ticks: {
                                color: chartColors.secondary,
                                font: {
                                    size: 11
                                }
                            }
                        }
                    }
                }
            });
        }

        initDashboardLiveRefresh(salesChartInstance, categoryChartInstance, revenueChartInstance);
    });

    function formatPeso(amount) {
        return '₱' + Number(amount).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }

    function renderChangeHtml(pct, fallbackText, suffix) {
        if (pct === null || pct === undefined) {
            return '<span>' + fallbackText + '</span>';
        }
        const positive = pct >= 0;
        return '<i class="fas fa-arrow-' + (positive ? 'up' : 'down') + '"></i><span>' +
            Math.abs(pct) + '% ' + suffix + '</span>';
    }

    function renderActivities(activities) {
        if (!activities || activities.length === 0) {
            return '<div class="empty-state"><i class="fas fa-inbox"></i><p>No recent activity to display</p></div>';
        }
        return activities.map(function(a) {
            return '<div class="activity-item">' +
                '<div class="activity-icon"><i class="fas fa-' + a.icon + '"></i></div>' +
                '<div class="activity-content"><p><strong>' + escapeHtml(a.username) + '</strong> - ' +
                escapeHtml(a.description) + '</p><span class="activity-time">' + escapeHtml(a.timestamp) +
                '</span></div></div>';
        }).join('');
    }

    function escapeHtml(text) {
        const div = document.createElement('div');
        div.textContent = text ?? '';
        return div.innerHTML;
    }

    function initDashboardLiveRefresh(salesChart, categoryChart, revenueChart) {
        const root = document.getElementById('dashboardLiveRoot');
        if (!root) return;

        const syncUrl = root.dataset.syncUrl;
        const pollMs = parseInt(root.dataset.pollMs || '5000', 10);
        const toastEl = document.getElementById('dashboardLiveToast');
        let lastVersion = null;
        let isRefreshing = false;

        function showToast(message) {
            if (!toastEl) return;
            toastEl.textContent = message;
            toastEl.hidden = false;
            toastEl.classList.add('dashboard-live-toast--visible');
            clearTimeout(window._dashboardLiveToastTimer);
            window._dashboardLiveToastTimer = setTimeout(function() {
                toastEl.classList.remove('dashboard-live-toast--visible');
                setTimeout(function() { toastEl.hidden = true; }, 300);
            }, 4500);
        }

        function updateCharts(payload) {
            if (salesChart && payload.sales_chart) {
                salesChart.data.labels = payload.sales_chart.labels;
                salesChart.data.datasets[0].data = payload.sales_chart.values;
                salesChart.update('none');
            }
            if (categoryChart && payload.category_chart) {
                categoryChart.data.labels = payload.category_chart.labels;
                categoryChart.data.datasets[0].data = payload.category_chart.values;
                categoryChart.data.datasets[0].backgroundColor = payload.category_chart.labels.map(function(_, i) {
                    return categoryPalette[i % categoryPalette.length];
                });
                categoryChart.update('none');
            }
            if (revenueChart && payload.revenue_chart) {
                revenueChart.data.labels = payload.revenue_chart.labels;
                revenueChart.data.datasets[0].data = payload.revenue_chart.values;
                revenueChart.update('none');
            }
        }

        function applyPayload(payload, showNotification) {
            const elProducts = document.getElementById('statProducts');
            const elOrders = document.getElementById('statOrders');
            const elCustomers = document.getElementById('statCustomers');
            const elRevenue = document.getElementById('statRevenue');
            const elOrdersChange = document.getElementById('statOrdersChange');
            const elCustomersChange = document.getElementById('statCustomersChange');
            const elRevenueChange = document.getElementById('statRevenueChange');
            const activityList = document.getElementById('recentActivityList');

            if (elProducts) elProducts.textContent = payload.total_products;
            if (elOrders) elOrders.textContent = payload.total_orders;
            if (elCustomers) elCustomers.textContent = payload.total_customers;
            if (elRevenue) elRevenue.textContent = formatPeso(payload.total_revenue);
            function setChangeEl(el, pct, fallback, suffix) {
                if (!el) return;
                el.className = 'stat-change' + (pct !== null && pct !== undefined && pct >= 0 ? ' positive' : '');
                el.innerHTML = renderChangeHtml(pct, fallback, suffix);
            }
            setChangeEl(elOrdersChange, payload.orders_change_pct, 'Last 30 days', 'vs prior 30 days');
            setChangeEl(elCustomersChange, payload.customers_change_pct, 'Registered accounts', 'new signups vs prior 30 days');
            setChangeEl(elRevenueChange, payload.revenue_change_pct, 'All-time order value', 'vs prior 30 days');

            updateCharts(payload);

            if (activityList) {
                activityList.innerHTML = renderActivities(payload.recent_activities);
            }

            if (showNotification) {
                showToast('Dashboard updated — new order received');
            }
        }

        async function poll() {
            if (isRefreshing) return;
            isRefreshing = true;
            try {
                const response = await fetch(syncUrl, {
                    credentials: 'same-origin',
                    headers: { Accept: 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
                });
                if (!response.ok) return;
                const payload = await response.json();
                if (payload.version === lastVersion) return;

                const isFirst = lastVersion === null;
                lastVersion = payload.version;

                if (!isFirst) {
                    applyPayload(payload, true);
                }
            } catch (e) {
                console.warn('[DashboardLive] sync failed', e);
            } finally {
                isRefreshing = false;
            }
        }

        poll();
        setInterval(poll, pollMs);
    }
</script>
{% endblock %}
