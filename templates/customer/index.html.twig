{% extends 'base.html.twig' %}

{% block title %}Customers - MVLLI{% endblock %}

{% block body %}
<style>
    @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@400;500;600;700&display=swap');
    
    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }
    
    body {
        background: #f5f5f5;
        font-family: 'DM Sans', sans-serif;
        color: #2d4a2b;
        line-height: 1.6;
    }
    
    .customers-container {
        padding: 40px 30px;
        max-width: 1400px;
        margin: 0 auto;
        background: #f5f5f5;
        min-height: calc(100vh - 80px);
    }
    
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }
    
    .page-title {
        font-family: 'Playfair Display', serif;
        font-size: 2rem;
        font-weight: 700;
        color: #2d4a2b;
        margin: 0;
    }
    
    .create-btn {
        padding: 14px 28px;
        background: linear-gradient(135deg, #2d4a2b 0%, #3a5a40 100%);
        color: white;
        text-decoration: none;
        border-radius: 10px;
        font-weight: 600;
        font-family: 'DM Sans', sans-serif;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(45, 74, 43, 0.3);
    }
    
    .create-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(45, 74, 43, 0.4);
        background: linear-gradient(135deg, #3a5a40 0%, #4a6b50 100%);
    }
    
    .customers-table {
        background: white;
        border-radius: 16px;
        padding: 28px;
        border: 1px solid #e0e0e0;
        box-shadow: 0 2px 4px rgba(45, 74, 43, 0.1);
        overflow: hidden;
    }
    
    .table-container {
        overflow-x: auto;
    }
    
    .data-table {
        width: 100%;
        border-collapse: collapse;
        font-family: 'DM Sans', sans-serif;
    }
    
    .data-table th {
        padding: 16px;
        text-align: left;
        color: #2d4a2b;
        font-weight: 600;
        font-family: 'DM Sans', sans-serif;
        background: #f8f9fa;
        border-bottom: 2px solid #e0e0e0;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-size: 0.85rem;
    }
    
    .data-table td {
        padding: 16px;
        border-bottom: 1px solid #e0e0e0;
        font-family: 'DM Sans', sans-serif;
        color: #333333;
    }
    
    .data-table tr:last-child td {
        border-bottom: none;
    }
    
    .data-table tr:hover {
        background: #f5f5f5;
    }
    
    .action-buttons {
        display: flex;
        gap: 8px;
    }
    
    .action-btn {
        padding: 8px 12px;
        background: #f5f5f5;
        border: 1px solid #e0e0e0;
        border-radius: 6px;
        color: #2d4a2b;
        text-decoration: none;
        font-size: 0.85rem;
        font-weight: 500;
        font-family: 'DM Sans', sans-serif;
        transition: all 0.2s ease;
    }
    
    .action-btn:hover {
        background: #2d4a2b;
        color: white;
    }
    
    .empty-state {
        text-align: center;
        padding: 60px 20px;
        color: #666666;
        font-family: 'DM Sans', sans-serif;
    }
    
    .empty-state i {
        font-size: 2.5rem;
        margin-bottom: 16px;
        opacity: 0.3;
        color: #2d4a2b;
    }
    
    @media (max-width: 768px) {
        .customers-container {
            padding: 20px;
        }
        
        .page-title {
            font-size: 1.8rem;
        }
        
        .data-table {
            font-size: 0.9rem;
        }
        
        .data-table th,
        .data-table td {
            padding: 12px;
        }
    }
</style>

<div class="customers-container">
    <div class="page-header">
        <h1 class="page-title">Customers</h1>
        <a href="{{ path('app_customer_new') }}" class="create-btn">
            <i class="fas fa-plus"></i> Create New Customer
        </a>
    </div>

    {% for message in app.flashes('success') %}
        <div style="background: #d4edda; color: #155724; padding: 12px; border-radius: 8px; margin-bottom: 20px; border-left: 4px solid #28a745;">
            {{ message }}
        </div>
    {% endfor %}

    {% if customers|length > 0 %}
    <div class="customers-table">
        <div class="table-container">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Customer Name</th>
                        <th>Username</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for customer in customers %}
                        <tr>
                            <td>{{ customer.name }}</td>
                            <td>{{ customer.email }}</td>
                            <td>{{ customer.customerName|default('N/A') }}</td>
                            <td>{{ customer.username|default('N/A') }}</td>
                            <td>
                                <div class="action-buttons">
                                    <a href="{{ path('app_customer_show', {'id': customer.id}) }}" class="action-btn" title="View">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a href="{{ path('app_customer_edit', {'id': customer.id}) }}" class="action-btn" title="Edit">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <form method="post" action="{{ path('app_customer_delete', {'id': customer.id}) }}" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this customer? This action cannot be undone.');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ customer.id) }}">
                                        <button type="submit" class="action-btn" title="Delete">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    {% else %}
    <div class="empty-state">
        <i class="fas fa-users"></i>
        <h3>No Customers Yet</h3>
        <p>Start by creating your first customer</p>
        <a href="{{ path('app_customer_new') }}" class="create-btn">
            <i class="fas fa-plus"></i> Create First Customer
        </a>
    </div>
    {% endif %}
</div>
{% endblock %}

