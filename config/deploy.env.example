# =============================================================================
# Railway variables — paste into: Web service → Variables → Raw Editor
# Replace YOUR_APP with your public Railway URL (e.g. finaldeployment-production.up.railway.app)
# Replace MySQL with your MySQL service name if different
# =============================================================================

# --- Required ---
APP_ENV=prod
APP_DEBUG=0
APP_SECRET=put_a_long_random_string_here_min_32_chars

DATABASE_URL=${{MySQL.MYSQL_URL}}

APP_URL=https://YOUR_APP.up.railway.app
DEFAULT_URI=https://YOUR_APP.up.railway.app
TRUSTED_PROXIES=REMOTE_ADDR

# Set MAILER_ENABLED=1 only when Brevo/SMTP is configured; otherwise registration auto-verifies (no 504 timeouts)
MAILER_ENABLED=1
MAILER_DSN=smtp://YOUR_BREVO_SMTP_LOGIN:YOUR_BREVO_SMTP_KEY@smtp-relay.brevo.com:587?timeout=10
MAILER_FROM_EMAIL=your-verified-sender@yourdomain.com
MAILER_FROM_NAME=MVLLI

GOOGLE_CLIENT_ID=your-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret
GOOGLE_STAFF_ALLOWED_EMAILS=jhamesmach@gmail.com

MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
CORS_ALLOW_ORIGIN=^https?://(localhost|127\.0\.0\.1|YOUR_APP\.up\.railway\.app)(:[0-9]+)?$

# --- First deploy: create admin when user table is empty (remove password after login works) ---
INITIAL_ADMIN_EMAIL=admin@mvlli.local
INITIAL_ADMIN_PASSWORD=ADMIN123
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_NAME=Admin

# --- Optional (entrypoint can set APP_URL from RAILWAY_PUBLIC_DOMAIN if omitted) ---
# PORT is set in Dockerfile (8080) — Railway Public Networking must target port 8080

# =============================================================================
# Google Cloud Console → Authorized redirect URI:
#   https://YOUR_APP.up.railway.app/connect/google/check
#
# Railway → Web service → Settings → Networking → Public port: 8080
#
# If DATABASE_URL is not set, add MySQL plugin and reference:
#   DATABASE_URL=${{MySQL.MYSQL_URL}}
# Or the entrypoint maps MYSQL_URL automatically when only MYSQL_URL exists.
# =============================================================================
