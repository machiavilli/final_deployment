# Railway / production environment variables (set in Railway dashboard)
# Copy values into Railway → your app service → Variables. Do NOT commit secrets.

# --- App ---
APP_ENV=prod
APP_DEBUG=0
APP_SECRET=generate_a_long_random_string
# Public URL of your deployed service (verification emails, Google OAuth)
APP_URL=https://your-service.up.railway.app
DEFAULT_URI=https://your-service.up.railway.app
# Trust Railway proxy (required for correct HTTPS URLs)
TRUSTED_PROXIES=REMOTE_ADDR

# --- Database (Railway MySQL service) ---
# In Railway → your WEB service → Variables → add:
#   DATABASE_URL=${{MySQL.MYSQL_URL}}
# Or rely on entrypoint mapping MYSQL_URL → DATABASE_URL automatically.
# Use a full server version to avoid DBAL deprecation warnings, e.g. serverVersion=8.0.31
DATABASE_URL=mysql://user:password@host:port/railway?serverVersion=8.0.31&charset=utf8mb4

# --- Brevo SMTP (transactional email) ---
# Option A: full DSN
MAILER_DSN=smtp://YOUR_BREVO_SMTP_LOGIN:YOUR_BREVO_SMTP_KEY@smtp-relay.brevo.com:587
# Option B: build DSN from parts (if you add MAILER_DSN resolver in Symfony)
MAILER_FROM_EMAIL=verified-sender@yourdomain.com
MAILER_FROM_NAME=MVLLI

# --- Google OAuth (staff sign-in) ---
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret
GOOGLE_STAFF_ALLOWED_EMAILS=jhamesmach@gmail.com

# --- CORS (mobile app / frontend origin) ---
CORS_ALLOW_ORIGIN=^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$

# --- Optional ---
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
FIXTURES_ADMIN_EMAIL=admin@mvlli.local
FIXTURES_ADMIN_PASSWORD=change_me

# Google Cloud Console → Authorized redirect URI:
#   https://your-service.up.railway.app/connect/google/check
#
# After first deploy, if tables are missing, run once in Railway shell:
#   php bin/console doctrine:migrations:migrate --no-interaction
#
# Railway → Settings → Networking → Public Networking → target port: 8080
# (must match PORT in deploy logs, e.g. "Nginx binding 0.0.0.0:8080")
